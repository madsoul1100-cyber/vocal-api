{
  "name": "vocal-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:check": "tsx scripts/db-check.ts",
    "seed:passwords": "tsx scripts/seed-passwords.ts",
    "seed:directory-categories": "tsx scripts/seed-directory-categories.ts"
  },
  "dependencies": {
    "@clerk/express": "^1.7.76",
    "@supabase/supabase-js": "^2.103.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
