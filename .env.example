# Database (PostgreSQL / RDS)
DATABASE_URL=postgresql://user:pass@host:5432/postgres
DATABASE_SSL=true

# JWT auth (min 32 characters for JWT_SECRET)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Supabase (service role for API — or use DATABASE_URL only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Organization
ORG_ID=
NEXT_PUBLIC_ORG_SLUG=demo

# CORS (comma-separated; vocal-web default http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# Local dev: impersonate a user without JWT when NODE_ENV=development
# DEV_BYPASS_AUTH=false
# DEV_USER_ID=

PORT=3001
