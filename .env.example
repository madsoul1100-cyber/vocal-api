# Database (PostgreSQL / RDS)
DATABASE_URL=postgresql://user:pass@host:5432/postgres
DATABASE_SSL=true

# JWT auth (min 32 characters for JWT_SECRET)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Supabase (service role for API — or use DATABASE_URL only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Organization
ORG_ID=
NEXT_PUBLIC_ORG_SLUG=demo

# CORS — comma-separated production/extra origins (no trailing slashes)
CORS_ORIGINS=https://demo.madsoul.in,https://nyleader.vercel.app,http://localhost:5173,http://localhost:3000,http://localhost:8080
# Allow any localhost port (local dev → remote API)
ALLOW_LOCALHOST_CORS=true
# Allow any https://*.vercel.app (Vercel preview + production)
ALLOW_VERCEL_CORS=true

# Local dev: impersonate a user without JWT when NODE_ENV=development
# DEV_BYPASS_AUTH=false
# DEV_USER_ID=

PORT=3001

# Staff profile photo + KYC (S3 preferred; else Supabase bucket staff-documents)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STAFF_STORAGE_BUCKET=staff-documents

# Staff OTP delivery — third-party providers
# OTP_DELIVERY_MODE=console  → log codes to API console (local / CI / test)
# OTP_DELIVERY_MODE=live     → AWS SES (email) + Twilio (SMS) — use in staging/production
# Default: console in NODE_ENV=development, live otherwise
OTP_DELIVERY_MODE=console
OTP_CHANNEL_PREFERENCE=sms_first
# sms | email | sms,email — use OTP_CHANNELS=sms when you only have Twilio (no SES/domain)
OTP_CHANNELS=sms,email
OTP_APP_NAME=Vocal
OTP_TTL_MINUTES=10
# Return dev_code in API response when using console mode (Sign-in UI shows it)
OTP_EXPOSE_DEV_CODE=true

# AWS SES (email OTP) — verify sender/domain in SES console (optional if OTP_CHANNELS=sms)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Twilio SMS (phone OTP) — use ONE of TWILIO_SMS_FROM or TWILIO_MESSAGING_SERVICE_SID
# TWILIO_SMS_FROM must be a number listed under YOUR account in Twilio Console → Phone Numbers
# Do NOT use +14155238886 (Twilio WhatsApp sandbox) unless that number is on your account
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+14155551234
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
